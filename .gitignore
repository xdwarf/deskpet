sprite-server/sprites/**/*.raw
sprite-server/sprites/**/*.sprite

# Simulator virtualenv
simulator/venv/
simulator/__pycache__/
simulator/*.pyc

# OS noise
.DS_Store
Thumbs.db
desktop.ini
